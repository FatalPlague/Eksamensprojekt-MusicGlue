<Window x:Class="MusicGlue.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicGlue"
        xmlns:viewmodels="clr-namespace:MusicGlue.ViewModels"
        xmlns:views="clr-namespace:MusicGlue.Views"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="MusicGlue" Height="1080" Width="1920">
        
        
    <Grid>
        <ContentControl Content="{Binding Path=CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
                    <views:HomeView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:OverviewViewModel}">
                    <views:Overview/>
                </DataTemplate>
                
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
